        if log_now:
            time.sleep(2)  # Øget tid lidt så den når at stoppe helt ved lavere fart
            tcp_pose = piper.GetArmEndPoseMsgs()
            tcp_position = [tcp_pose.end_pose.X_axis,
                tcp_pose.end_pose.Y_axis,
                tcp_pose.end_pose.Z_axis,
                tcp_pose.end_pose.RX_axis,
